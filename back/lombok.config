# Empeche Lombok de remonter chercher d'autres lombok.config plus haut
config.stopBubbling = true

# Annote le code genere par Lombok avec @lombok.Generated :
# JaCoCo (>= 0.8.2) exclut alors automatiquement ce boilerplate du rapport de couverture
# (getters/setters/equals/hashCode/toString/builder), qui faussait le pourcentage.
lombok.addLombokGeneratedAnnotation = true
